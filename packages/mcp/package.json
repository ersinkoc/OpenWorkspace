{
  "name": "@openworkspace/mcp",
  "version": "0.1.0",
  "description": "MCP server with tool registry, stdio and HTTP/SSE transports",
  "keywords": ["mcp", "mcp-server", "model-context-protocol", "claude", "ai-tools", "json-rpc", "stdio", "sse", "google-workspace", "typescript"],
  "author": "Ersin Koc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ersinkoc/openworkspace.git"
  },
  "homepage": "https://openworkspace.oxog.dev",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ows-mcp": "./dist/serve.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/serve.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openworkspace/core": "workspace:*",
    "@openworkspace/gmail": "workspace:*",
    "@openworkspace/calendar": "workspace:*",
    "@openworkspace/drive": "workspace:*",
    "@openworkspace/sheets": "workspace:*",
    "@openworkspace/tasks": "workspace:*",
    "@openworkspace/contacts": "workspace:*",
    "@openworkspace/docs": "workspace:*",
    "@openworkspace/slides": "workspace:*",
    "@openworkspace/classroom": "workspace:*",
    "@openworkspace/forms": "workspace:*",
    "@openworkspace/chat": "workspace:*",
    "@openworkspace/keep": "workspace:*",
    "@openworkspace/appscript": "workspace:*",
    "@openworkspace/people": "workspace:*",
    "@openworkspace/groups": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
