{
  "name": "@openworkspace/cli",
  "version": "0.1.0",
  "description": "Zero-dependency CLI for Google Workspace services",
  "keywords": [
    "cli",
    "command-line",
    "google-workspace",
    "ows",
    "terminal",
    "zero-dependency",
    "typescript",
    "gmail",
    "calendar",
    "drive"
  ],
  "author": "Ersin Koc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ersinkoc/openworkspace.git",
    "directory": "packages/cli"
  },
  "homepage": "https://openworkspace.oxog.dev",
  "bugs": {
    "url": "https://github.com/ersinkoc/openworkspace/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ows": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openworkspace/core": "workspace:*",
    "@openworkspace/mcp": "workspace:*",
    "@openworkspace/pipeline": "workspace:*",
    "@openworkspace/gmail": "workspace:*",
    "@openworkspace/calendar": "workspace:*",
    "@openworkspace/drive": "workspace:*",
    "@openworkspace/sheets": "workspace:*",
    "@openworkspace/docs": "workspace:*",
    "@openworkspace/slides": "workspace:*",
    "@openworkspace/contacts": "workspace:*",
    "@openworkspace/tasks": "workspace:*",
    "@openworkspace/chat": "workspace:*",
    "@openworkspace/classroom": "workspace:*",
    "@openworkspace/forms": "workspace:*",
    "@openworkspace/appscript": "workspace:*",
    "@openworkspace/people": "workspace:*",
    "@openworkspace/groups": "workspace:*",
    "@openworkspace/keep": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "files": [
    "dist"
  ]
}
